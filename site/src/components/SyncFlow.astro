---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="flow" aria-hidden="true">
  <div class="flow-panel flow-jf">
    <div class="flow-head">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 2 20h20L12 2zm0 5 6 10H6l6-10z"/></svg>
      <span>Jellyfin · Playback</span>
      <span class="flow-badge">Now playing</span>
    </div>
    <div class="flow-film">
      <div class="film-poster">
        <img src={`${base}/posters/barbie.jpg`} alt="Barbie" loading="lazy" decoding="async" />
      </div>
      <div class="film-meta">
        <div class="film-title">Barbie</div>
        <div class="film-sub">2023 · Greta Gerwig</div>
        <div class="film-progress">
          <span class="progress-fill"></span>
        </div>
        <div class="film-time">1:45 · 100%</div>
      </div>
    </div>
    <div class="flow-status">
      <span class="status-check">✓</span>
      <span>Playback complete</span>
    </div>
  </div>

  <div class="flow-pipe" role="presentation">
    <svg viewBox="0 0 120 120" class="flow-pipe-svg" preserveAspectRatio="none">
      <defs>
        <linearGradient id="pipegrad" x1="0" y1="50%" x2="100%" y2="50%">
          <stop offset="0%" stop-color="#aa5cc3"/>
          <stop offset="50%" stop-color="#40bcf4"/>
          <stop offset="100%" stop-color="#00e054"/>
        </linearGradient>
      </defs>
      <path d="M0 60 L120 60" stroke="url(#pipegrad)" stroke-width="2" stroke-linecap="round"/>
    </svg>
    <span class="pipe-dot"></span>
    <span class="pipe-dot"></span>
    <span class="pipe-dot"></span>
    <span class="pipe-label">TMDb 346698</span>
  </div>

  <div class="flow-panel flow-lb">
    <div class="flow-head">
      <span class="flow-dots">
        <i></i><i></i><i></i>
      </span>
      <span>Letterboxd · Diary</span>
      <span class="flow-badge badge-live">Live</span>
    </div>
    <div class="flow-diary">
      <div class="diary-date">
        <span class="diary-date-m">APR</span>
        <span class="diary-date-d">17</span>
      </div>
      <div class="diary-body">
        <div class="diary-title-row">
          <span class="diary-title">Barbie</span>
          <span class="diary-year">2023</span>
        </div>
        <div class="diary-stars-row">
          <span class="diary-stars">★★★★½</span>
          <span class="diary-heart">♥</span>
        </div>
        <div class="diary-tags">
          <span class="tag">rewatched</span>
          <span class="tag tag-new">+ just now</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .flow {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 32px;
    align-items: stretch;
    width: 100%;
  }
  @media (max-width: 860px) {
    .flow { grid-template-columns: 1fr; gap: 16px; }
    .flow-pipe { display: none; }
  }
  @media (max-width: 520px) {
    .flow-panel { padding: 18px; min-height: 0; gap: 14px; }
    .flow-head { font-size: 11px; }
  }

  .flow-panel {
    background: linear-gradient(180deg, var(--bg-elev), var(--bg-elev-2));
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    min-height: 260px;
  }
  .flow-jf { border-top: 2px solid var(--jf-purple); }
  .flow-lb { border-top: 2px solid var(--lb-green); }

  .flow-head {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .flow-head svg { color: var(--jf-purple); }
  .flow-head > span:nth-child(2) { flex: 1; }
  .flow-badge {
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(170,92,195,0.15);
    color: var(--jf-purple);
    letter-spacing: 0.06em;
  }
  .badge-live {
    background: rgba(0,224,84,0.12);
    color: var(--lb-green);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .badge-live::before {
    content: '';
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--lb-green);
    box-shadow: 0 0 0 0 rgba(0,224,84,0.6);
    animation: pulse 1.8s ease-out infinite;
  }

  .flow-dots {
    display: inline-flex;
    gap: 3px;
  }
  .flow-dots i {
    width: 8px; height: 8px; border-radius: 50%;
  }
  .flow-dots i:nth-child(1) { background: var(--lb-green); }
  .flow-dots i:nth-child(2) { background: var(--lb-blue); }
  .flow-dots i:nth-child(3) { background: var(--lb-orange); }

  .flow-film {
    display: flex;
    gap: 14px;
    align-items: center;
    flex: 1;
  }
  .film-poster {
    position: relative;
    width: 58px;
    height: 86px;
    border-radius: 6px;
    background: var(--bg);
    border: 1px solid var(--border);
    flex-shrink: 0;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35);
  }
  .film-poster img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .film-meta { flex: 1; min-width: 0; }
  .film-title { font-size: 14px; color: var(--text); font-weight: 600; }
  .film-sub { font-size: 12px; color: var(--text-dim); margin-bottom: 8px; }
  .film-progress {
    width: 100%;
    height: 3px;
    border-radius: 999px;
    background: var(--border);
    overflow: hidden;
    margin-bottom: 4px;
  }
  .progress-fill {
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, var(--jf-purple), var(--jf-blue));
    animation: fill 3s ease-out infinite;
    transform-origin: left;
  }
  @keyframes fill {
    0% { transform: scaleX(0); }
    80% { transform: scaleX(1); }
    100% { transform: scaleX(1); }
  }
  .film-time { font-size: 11px; color: var(--text-dim); font-family: var(--font-mono); }

  .flow-status {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: rgba(0,224,84,0.08);
    border: 1px solid rgba(0,224,84,0.2);
    border-radius: 8px;
    font-size: 12px;
    color: var(--lb-green);
  }
  .status-check {
    width: 16px; height: 16px;
    border-radius: 50%;
    background: var(--lb-green);
    color: #04140a;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
  }

  .flow-pipe {
    position: relative;
    width: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .flow-pipe-svg { width: 100%; height: 40px; }
  .pipe-dot {
    position: absolute;
    top: 50%;
    left: 0;
    width: 6px;
    height: 6px;
    margin-top: -3px;
    border-radius: 50%;
    background: var(--lb-green);
    box-shadow: 0 0 10px var(--lb-green);
    animation: travel 2.4s linear infinite;
  }
  .pipe-dot:nth-child(3) { animation-delay: 0.8s; background: var(--lb-blue); box-shadow: 0 0 10px var(--lb-blue); }
  .pipe-dot:nth-child(4) { animation-delay: 1.6s; background: var(--lb-orange); box-shadow: 0 0 10px var(--lb-orange); }
  @keyframes travel {
    0%   { left: 0%; opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }
  .pipe-label {
    position: absolute;
    top: 62%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 0.05em;
    background: var(--bg);
    padding: 2px 8px;
    border: 1px solid var(--border);
    border-radius: 999px;
    white-space: nowrap;
  }

  .flow-diary {
    display: flex;
    gap: 14px;
    flex: 1;
  }
  .diary-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 52px;
    padding: 6px 4px;
    border-right: 1px solid var(--border);
  }
  .diary-date-m {
    font-size: 11px;
    color: var(--lb-green);
    font-weight: 700;
    letter-spacing: 0.12em;
  }
  .diary-date-d {
    font-size: 28px;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .diary-body { flex: 1; display: flex; flex-direction: column; gap: 6px; }
  .diary-title-row { display: flex; align-items: baseline; gap: 8px; }
  .diary-title { color: var(--text); font-weight: 600; font-size: 15px; }
  .diary-year { color: var(--text-dim); font-size: 12px; }
  .diary-stars-row { display: flex; align-items: center; gap: 10px; }
  .diary-stars { color: var(--lb-green); font-family: var(--font-mono); letter-spacing: 1px; font-size: 14px; }
  .diary-heart { color: var(--lb-orange); font-size: 14px; }

  .diary-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 999px;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .tag-new {
    background: rgba(0,224,84,0.1);
    border-color: rgba(0,224,84,0.3);
    color: var(--lb-green);
  }
</style>
